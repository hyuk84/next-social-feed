{
  "name": "next-social-feed",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:local",
    "dev:local": "set -a; . ./.env.local; set +a; APP_ENV=local next dev",
    "dev:dev": "set -a; . ./.env.dev; set +a; APP_ENV=dev next dev",
    "build": "pnpm build:prod",
    "build:prod": "if [ -f .env.prod ]; then set -a; . ./.env.prod; set +a; fi; APP_ENV=prod next build",
    "start": "pnpm start:prod",
    "start:prod": "if [ -f .env.prod ]; then set -a; . ./.env.prod; set +a; fi; APP_ENV=prod next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
